<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aifred.engine</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Library/Application Support/Aifred/bin/AifredEngine</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Library/Application Support/Aifred/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Application Support/Aifred/logs/launchd.err.log</string>
</dict>
</plist>
