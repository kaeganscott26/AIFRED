#!/bin/sh
set -eu

AIFRED_ROOT="/Library/Application Support/Aifred"
ENGINE="$AIFRED_ROOT/bin/AifredEngine"
PLIST="/Library/LaunchAgents/com.aifred.engine.plist"
LOG="$AIFRED_ROOT/logs/postinstall.log"

mkdir -p "$AIFRED_ROOT/logs" "$AIFRED_ROOT/models"
chmod 755 "$ENGINE" 2>/dev/null || true

log() {
  printf '%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$1" >> "$LOG"
}

console_user="$(stat -f '%Su' /dev/console 2>/dev/null || true)"
if [ -n "$console_user" ] && [ "$console_user" != "root" ] && [ -f "$PLIST" ]; then
  user_id="$(id -u "$console_user")"
  launchctl bootout "gui/$user_id" "$PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$user_id" "$PLIST" >/dev/null 2>&1 || log "launchctl bootstrap failed"
  launchctl kickstart -k "gui/$user_id/com.aifred.engine" >/dev/null 2>&1 || log "launchctl kickstart failed"
fi

if command -v ollama >/dev/null 2>&1; then
  ollama serve >/dev/null 2>&1 &
  sleep 2
  ollama list | grep -qi '^aifred' && exit 0
  ollama list | grep -qi '^llama3.2:3b' || ollama pull llama3.2:3b >> "$LOG" 2>&1 || true
  modelfile="$AIFRED_ROOT/models/aifred/Modelfile"
  if [ -f "$modelfile" ]; then
    ollama create aifred -f "$modelfile" >> "$LOG" 2>&1 || true
  else
    log "AIFRED Modelfile missing at $modelfile"
  fi
else
  log "ollama command not found; AIFRED engine installed but local model setup is pending"
fi

exit 0
